# ============================================
# MAIVÉ Backend Environment Configuration
# ============================================

# Server Configuration
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/maive
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/maive

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=30d

# Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Payment Configuration
# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Algeria Payment (CIB/Edahabia) - Integration with local providers
CIB_MERCHANT_ID=your-cib-merchant-id
CIB_API_KEY=your-cib-api-key
EDAHABIA_MERCHANT_ID=your-edahabia-merchant-id
EDAHABIA_API_KEY=your-edahabia-api-key

# WhatsApp API (Twilio or similar)
WHATSAPP_API_KEY=your-whatsapp-api-key
WHATSAPP_PHONE_NUMBER=your-whatsapp-number

# Admin Credentials (for initial setup)
ADMIN_EMAIL=admin@maive.com
ADMIN_PASSWORD=Admin123!
